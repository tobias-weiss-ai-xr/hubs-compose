# Hubs Compose — Environment Configuration
# Copy this file to .env and customize for your deployment.
# Generate unique secrets: head -c 64 /dev/urandom | base64

# ── Domain ──────────────────────────────────────────────
HUBS_HOST=hubs.tobias-weiss.org

# ── Database ────────────────────────────────────────────
DB_CREDENTIALS=postgres

# ── Security Secrets ─────────────────────────────────────
# IMPORTANT: Generate unique values for each! Never use defaults in production.
# secret_key_base: Phoenix session/cookie encryption (64+ chars)
SECRET_KEY_BASE=GENERATE_A_UNIQUE_VALUE
# Guardian JWT signing key (64+ chars)
GUARDIAN_SECRET_KEY=GENERATE_A_UNIQUE_VALUE
# AES key for encrypting uploaded files on disk (32 hex chars)
UPLOAD_ENCRYPTION_KEY=GENERATE_A_UNIQUE_VALUE
# WebPush VAPID keys — generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=GENERATE_A_UNIQUE_VALUE
VAPID_PRIVATE_KEY=GENERATE_A_UNIQUE_VALUE
VAPID_SUBJECT=mailto:admin@example.com
# Admin panel access key (sent as x-ret-admin-access-key header)
RETICULUM_ADMIN_KEY=GENERATE_A_UNIQUE_VALUE
# PostgREST API password (must match POSTGREST_INTERNAL_PASSWORD in docker-compose)
POSTGREST_PASSWORD=GENERATE_A_UNIQUE_VALUE
# Grafana admin password
GRAFANA_PASSWORD=GENERATE_A_UNIQUE_VALUE

# ── SMTP (Mailcow / Postfix) ────────────────────────────
SMTP_SERVER=mail.tobias-weiss.org
SMTP_PORT=587
SMTP_USERNAME=hubs@tobias-weiss.org
SMTP_PASSWORD=GENERATE_A_SMTP_PASSWORD
EMAIL_FROM=hubs@tobias-weiss.org

# ── Internal Service Hostnames ──────────────────────────
DIALOG_HOSTNAME=hubs.local
DIALOG_PORT=4443
HUBS_ADMIN_INTERNAL_HOSTNAME=hubs-admin
HUBS_CLIENT_INTERNAL_HOSTNAME=hubs-client
SPOKE_INTERNAL_HOSTNAME=spoke
POSTGREST_INTERNAL_HOSTNAME=postgrest

# ── Perms Key ───────────────────────────────────────────
# Path inside the reticulum container to the RSA private key used
# for signing PermsTokens (RS512 JWTs). The Dockerfile copies
# container/dev-perms.pem to this path by default.
PERMS_KEY_PATH=/etc/perms.pem

# ── Dialog Certificate Paths ────────────────────────────
DIALOG_AUTH_KEY_PATH=/etc/perms.pub.pem
DIALOG_CERT_FULLCHAIN_PATH=/etc/ssl/fullchain.pem
DIALOG_CERT_PRIVKEY_PATH=/etc/ssl/privkey.pem
