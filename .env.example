# Hubs Compose — Environment Configuration
# Copy this file to .env and customize for your deployment.

# ── Domain ──────────────────────────────────────────────
HUBS_HOST=hubs.tobias-weiss.org

# ── Database ────────────────────────────────────────────
DB_CREDENTIALS=postgres

# ── SMTP (Mailcow / Postfix) ────────────────────────────
SMTP_SERVER=mail.tobias-weiss.org
SMTP_PORT=587
SMTP_USERNAME=hubs@tobias-weiss.org
SMTP_PASSWORD=HubsApp2026
EMAIL_FROM=hubs@tobias-weiss.org

# ── Internal Service Hostnames ──────────────────────────
DIALOG_HOSTNAME=hubs.local
DIALOG_PORT=4443
HUBS_ADMIN_INTERNAL_HOSTNAME=hubs-admin
HUBS_CLIENT_INTERNAL_HOSTNAME=hubs-client
SPOKE_INTERNAL_HOSTNAME=spoke
POSTGREST_INTERNAL_HOSTNAME=postgrest

# ── Perms Key ───────────────────────────────────────────
# Path inside the reticulum container to the RSA private key used
# for signing PermsTokens (RS512 JWTs). The Dockerfile copies
# container/dev-perms.pem to this path by default.
PERMS_KEY_PATH=/etc/perms.pem

# ── Dialog Certificate Paths ────────────────────────────
DIALOG_AUTH_KEY_PATH=/etc/perms.pub.pem
DIALOG_CERT_FULLCHAIN_PATH=/etc/ssl/fullchain.pem
DIALOG_CERT_PRIVKEY_PATH=/etc/ssl/privkey.pem
